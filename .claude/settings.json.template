{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/detect-project.sh 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "[ -f LEARNINGS.md ] && [ -n \"$(find LEARNINGS.md -mtime +7 2>/dev/null)\" ] && echo 'LEARNINGS.md untouched for 7+ days — run /retro (weekly learning checkpoint)' || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "TOOL_INPUT=$(cat | node -e 'let d=\"\";process.stdin.on(\"data\",c=>d+=c);process.stdin.on(\"end\",()=>{try{const j=JSON.parse(d);process.stdout.write(j.tool_input?.file_path||\"\")}catch{}})'); case \"$TOOL_INPUT\" in *.env*|*package-lock.json*|*.git/*) echo 'BLOCKED: Protected file' >&2; exit 2;; esac"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "TOOL_CMD=$(cat | node -e 'let d=\"\";process.stdin.on(\"data\",c=>d+=c);process.stdin.on(\"end\",()=>{try{const j=JSON.parse(d);process.stdout.write(j.tool_input?.command||\"\")}catch{}})'); if [ -f .git ]; then case \"$TOOL_CMD\" in *'git merge'*|*'git push'*main*|*'git push'*master*) echo 'BLOCKED: integration git ops (merge, push to main) run in the canonical checkout, not a worktree — see rules/git-isolation.md' >&2; exit 2;; esac; fi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bun run format 2>/dev/null || npx prettier --write \"$TOOL_INPUT\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "echo '--- Session end check ---' && (npx tsc --noEmit 2>&1 | tail -3 || true)"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "bun run *",
      "npm run *",
      "npx tsc --noEmit",
      "npx prettier *",
      "git status",
      "git diff *",
      "git log *",
      "git add *",
      "git commit *",
      "git push *",
      "git stash *",
      "git checkout *",
      "git worktree *"
    ]
  },
  "preferences": {
    "model": "opus",
    "thinkingEnabled": true
  }
}
