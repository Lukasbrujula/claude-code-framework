{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/detect-project.sh 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "case \"$TOOL_INPUT\" in *.env*|*package-lock.json*|*.git/*) echo 'BLOCKED: Protected file' >&2; exit 2;; esac"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bun run format 2>/dev/null || npx prettier --write \"$TOOL_INPUT\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "echo '--- Session end check ---' && (npx tsc --noEmit 2>&1 | tail -3 || true)"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "bun run *",
      "npm run *",
      "npx tsc --noEmit",
      "npx prettier *",
      "git status",
      "git diff *",
      "git log *",
      "git add *",
      "git commit *",
      "git push *",
      "git stash *",
      "git checkout *",
      "git worktree *"
    ]
  },
  "preferences": {
    "model": "opus",
    "thinkingEnabled": true
  }
}
